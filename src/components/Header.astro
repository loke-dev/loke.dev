---
import HeaderSearch from '@/components/HeaderSearch'
import { getAllTopics } from '@/utils/sanity.queries'

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/tools', label: 'Tools' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
]
const topics = await getAllTopics()
---

<header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-backdrop-filter:bg-background/60">
  <div class="container mx-auto flex h-16 items-center justify-between px-4 md:px-8">
    <a href="/" class="flex items-center">
      <span class="text-xl font-bold tracking-tight">loke.dev</span>
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.slice(0, 3).map(({ href, label }) => (
        <a
          href={href}
          class="nav-link-animate text-sm font-medium text-muted-foreground transition-colors hover:text-accent"
        >
          {label}
        </a>
      ))}
      <div class="group relative">
        <a
          href="/blog"
          class="nav-link-animate inline-flex items-center gap-1 text-sm font-medium text-muted-foreground transition-colors hover:text-accent"
          aria-haspopup="true"
        >
          Blog
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </a>
        <div class="invisible absolute left-1/2 top-full z-50 w-64 -translate-x-1/2 pt-3 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
          <nav class="rounded-lg border border-border bg-card p-2 shadow-xl" aria-label="Blog topics">
            <a href="/blog" class="block rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-secondary">All posts</a>
            {topics.length > 0 && <div class="my-1 border-t border-border"></div>}
            {topics.map((topic) => (
              <a href={`/topics/${topic.slug.current}`} class="block rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground">
                {topic.title}
              </a>
            ))}
          </nav>
        </div>
      </div>
      {navLinks.slice(3).map(({ href, label }) => (
        <a
          href={href}
          class="nav-link-animate text-sm font-medium text-muted-foreground transition-colors hover:text-accent"
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-0.5">
      <HeaderSearch client:load />
      <div id="mobile-nav-root" class="md:hidden">
        <button
          type="button"
          data-mobile-nav-open
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-nav-dialog"
          class="p-2 text-muted-foreground hover:text-foreground"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>

        <dialog
          id="mobile-nav-dialog"
          aria-modal="true"
          aria-label="Navigation menu"
          class="mobile-menu-dialog fixed inset-0 m-0 h-full w-3/4 max-w-sm ml-auto bg-background border-l p-6 shadow-lg"
        >
          <button
            type="button"
            data-mobile-nav-close
            aria-label="Close navigation menu"
            class="absolute top-4 right-4 p-2 text-muted-foreground hover:text-foreground"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>

          <nav class="flex flex-col gap-6 mt-8" aria-label="Mobile navigation">
            {navLinks.slice(0, 3).map(({ href, label }) => (
              <a
                href={href}
                class="nav-link-animate text-base font-medium text-muted-foreground transition-colors hover:text-accent"
              >
                {label}
              </a>
            ))}
            <div class="-mt-2">
              <a href="/blog" class="nav-link-animate text-base font-medium text-muted-foreground transition-colors hover:text-accent">Blog</a>
              {topics.length > 0 && (
                <details class="mt-2">
                  <summary class="cursor-pointer text-sm text-muted-foreground marker:text-accent">Topics</summary>
                  <div class="mt-3 flex flex-col gap-3 border-l border-border pl-4">
                    <a href="/blog" class="text-sm font-medium text-foreground hover:text-accent">All posts</a>
                    {topics.map((topic) => (
                      <a href={`/topics/${topic.slug.current}`} class="text-sm text-muted-foreground hover:text-accent">
                        {topic.title}
                      </a>
                    ))}
                  </div>
                </details>
              )}
            </div>
            {navLinks.slice(3).map(({ href, label }) => (
              <a
                href={href}
                class="nav-link-animate text-base font-medium text-muted-foreground transition-colors hover:text-accent"
              >
                {label}
              </a>
            ))}
          </nav>
        </dialog>
      </div>
    </div>
  </div>
</header>

<script>
  import { setupMobileMenu } from '@/scripts/mobile-menu'
  setupMobileMenu()
  document.addEventListener('astro:after-swap', setupMobileMenu)
</script>
