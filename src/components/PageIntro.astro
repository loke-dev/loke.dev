---
interface Props {
  eyebrow?: string
  title: string
  description?: string
  compact?: boolean
}

const { eyebrow, title, description, compact = false } = Astro.props
---

<header class:list={[
  'page-intro border-b border-border/70',
  compact ? 'pb-8' : 'pb-10 md:pb-12',
]}>
  {eyebrow && (
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">
      {eyebrow}
    </p>
  )}
  <h1 class="mt-3 max-w-3xl text-4xl font-bold tracking-tight md:text-5xl">
    {title}
  </h1>
  {description && (
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted-foreground">
      {description}
    </p>
  )}
</header>
