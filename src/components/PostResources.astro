---
import type { PostResource } from '@/lib/sanity/types'

interface Props {
  resources: PostResource[]
}

const { resources } = Astro.props
---

{
  resources.length > 0 && (
    <section
      class="not-prose mt-14 rounded-2xl border border-accent/35 bg-gradient-to-br from-accent/12 via-card to-chart-2/10 p-6 shadow-[0_0_0_1px_oklch(1_0_0/0.04)_inset] md:p-8"
      aria-label="Resources"
    >
      <div class="flex items-center gap-3">
        <span
          class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent/20 text-accent ring-1 ring-accent/25"
          aria-hidden="true"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
          </svg>
        </span>
        <h2 class="text-lg font-semibold tracking-tight text-foreground">Resources</h2>
      </div>
      <ul class="mt-5 space-y-3">
        {resources.map((r) => (
          <li>
            <a
              href={r.url}
              class="group flex items-start gap-3 rounded-lg px-2 py-2 transition-colors hover:bg-background/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span
                class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-accent shadow-[0_0_8px_oklch(72%_0.2_70/0.6)]"
                aria-hidden="true"
              />
              <span class="font-medium text-foreground underline decoration-accent/50 underline-offset-4 transition-all group-hover:decoration-accent group-hover:text-accent">
                {r.title}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
