---
import type { PostListItem } from '@/lib/sanity/types'
import { formatDate } from '@/lib/sanity/helpers'

interface Props {
  posts: PostListItem[]
}

const { posts } = Astro.props
---

{
  posts.length > 0 && (
    <aside class="not-prose mt-16" aria-label="Related posts">
      <div class="relative overflow-hidden rounded-2xl border-2 border-accent/40 bg-linear-to-b from-accent/10 via-card to-card p-1 shadow-[0_24px_60px_-28px_oklch(72%_0.2_70/0.35)]">
        <div class="rounded-[0.9rem] bg-card/95 px-5 py-7 md:px-8 md:py-9">
          <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">
                Keep reading
              </p>
              <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground">
                Related posts
              </h2>
              <p class="mt-1 max-w-xl text-sm text-muted-foreground">
                More posts where the tags line up with this one.
              </p>
            </div>
          </div>
          <ul class="mt-8 grid gap-4 md:grid-cols-3">
            {posts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.slug.current}`}
                  data-astro-prefetch="hover"
                  class="group relative flex h-full flex-col overflow-hidden rounded-xl border border-border bg-background/80 p-4 transition-[transform,border-color,box-shadow] duration-200 after:pointer-events-none after:absolute after:inset-x-4 after:top-0 after:h-px after:bg-gradient-to-r after:from-transparent after:via-accent/60 after:to-transparent hover:-translate-y-1 hover:border-accent/50 hover:shadow-[0_16px_40px_-20px_oklch(72%_0.18_70/0.45)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  <span class="text-[0.65rem] font-medium uppercase tracking-wider text-muted-foreground">
                    <time datetime={post.date}>{formatDate(post.date)}</time>
                    {post.readingTime ? (
                      <>
                        <span aria-hidden="true"> · </span>
                        {post.readingTime} min read
                      </>
                    ) : null}
                  </span>
                  <span class="mt-2 text-base font-semibold text-foreground transition-colors group-hover:text-accent">
                    {post.title}
                  </span>
                  <span class="mt-2 line-clamp-2 text-sm text-muted-foreground">
                    {post.description}
                  </span>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent">
                    Read
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      class="transition-transform group-hover:translate-x-0.5"
                    >
                      <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </aside>
  )
}
