---
import type { PostListItem } from '@/lib/sanity/types'
import { formatDate, getSanityImageUrl, getSanityImageSrcSet } from '@/lib/sanity/helpers'
import { getPostUpdatedDisplay } from '@/lib/sanity/post-display'

interface Props {
  post: PostListItem
  imageWidth?: number
  imageHeight?: number
}

const { post, imageWidth = 600, imageHeight = 338 } = Astro.props

const listQuality = 72
const srcWidths = [Math.round(imageWidth / 2), imageWidth, Math.round(imageWidth * 1.5)]
const imageUrl = getSanityImageUrl(post.image, imageWidth, imageHeight, listQuality)
const srcSet = getSanityImageSrcSet(
  post.image,
  srcWidths,
  imageHeight,
  listQuality,
  imageWidth
)
const updatedDisplay = getPostUpdatedDisplay(post)
---

<article class="surface-interactive group flex h-full flex-col overflow-hidden rounded-lg border transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-accent/35 hover:shadow-[0_20px_50px_-28px_oklch(72%_0.16_70/0.28)]">
  <a
    href={`/blog/${post.slug.current}`}
    data-astro-prefetch="hover"
    class="flex h-full flex-col"
    aria-labelledby={`post-title-${post.slug.current}`}
  >
    {imageUrl && (
      <div class="aspect-video w-full overflow-hidden bg-muted">
        <img
          src={imageUrl}
          srcset={srcSet || undefined}
          sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
          alt={post.imageAlt || ''}
          loading="lazy"
          decoding="async"
          width={imageWidth}
          height={imageHeight}
          class="h-full w-full object-cover"
        />
      </div>
    )}
    <div class="flex flex-1 flex-col p-6">
      <div class="mb-2 flex flex-wrap items-center gap-x-2 gap-y-0.5 text-sm text-muted-foreground">
        <time datetime={post.date}>{formatDate(post.date)}</time>
        {post.readingTime ? (
          <>
            <span aria-hidden="true">·</span>
            <span>{post.readingTime} min read</span>
          </>
        ) : null}
        {updatedDisplay ? (
          <>
            <span aria-hidden="true">·</span>
            <span>
              Updated <time datetime={updatedDisplay.datetime}>{updatedDisplay.label}</time>
            </span>
          </>
        ) : null}
      </div>
      <h2
        id={`post-title-${post.slug.current}`}
        class="mb-2 text-xl font-bold tracking-tight group-hover:underline"
      >
        {post.title}
      </h2>
      <p class="flex-1 text-muted-foreground line-clamp-3">
        {post.description}
      </p>
      {post.tags && post.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1">
          {post.tags.map((tag) => (
            <span class="rounded-full bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
              {tag}
            </span>
          ))}
        </div>
      )}
      <div class="mt-4">
        <span class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:underline">
          Read article
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
