---
import { toHTML } from '@portabletext/to-html'
import { createImageUrlBuilder } from '@sanity/image-url'
import { client } from '@/lib/sanity/client'
import { processBodyWithHighlighting } from '@/lib/sanity/process-body.server'
import { renderArticleDiagram } from '@/lib/article-diagrams'
import type { Post } from '@/lib/sanity/types'

interface Props {
  value: Post['body']
}

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;')
}

const { value } = Astro.props
const builder = createImageUrlBuilder(client)

const processedBlocks = await processBodyWithHighlighting(value)

const html = toHTML(processedBlocks as Parameters<typeof toHTML>[0], {
  components: {
    types: {
      code: ({ value }) => {
        const v = value as Record<string, unknown>
        if (v.highlightedHtml) {
          return `<div class="not-prose code-block my-6">${v.highlightedHtml}</div>`
        }
        return `<pre><code>${String(v.code ?? '')}</code></pre>`
      },
      callout: ({ value }) => {
        const v = value as { text?: string; tone?: string }
        const tone = (v.tone ?? 'info').replace(/[^a-z0-9-]/g, '')
        const toneClasses = {
          info: 'border-accent/70 bg-accent/10 text-foreground',
          warning: 'border-amber-400/80 bg-amber-400/10 text-foreground',
          success: 'border-emerald-400/80 bg-emerald-400/10 text-foreground',
        }[tone] ?? 'border-border bg-card text-foreground'
        return `<aside class="callout callout-${escapeHtml(tone)} not-prose my-6 rounded-lg border-l-4 p-4 ${toneClasses}" role="note"><p class="m-0 leading-relaxed">${escapeHtml(v.text ?? '')}</p></aside>`
      },
      diagram: ({ value }) => renderArticleDiagram(value as { kind?: unknown; caption?: unknown }),
      image: ({ value }) => {
        const v = value as Record<string, unknown>
        if (!v.asset) return ''
        const src400 = builder.image(v).width(400).auto('format').url()
        const src800 = builder.image(v).width(800).auto('format').url()
        const src1200 = builder.image(v).width(1200).auto('format').url()
        const alt = String(v.alt ?? '')
        return `<figure class="my-8">
          <picture>
            <source srcset="${src400} 400w, ${src800} 800w, ${src1200} 1200w" sizes="(max-width: 400px) 100vw, (max-width: 800px) 100vw, 800px" />
            <img src="${src400}" alt="${escapeHtml(alt)}" loading="lazy" decoding="async" class="rounded-lg w-full" />
          </picture>
          ${alt ? `<figcaption class="text-sm text-center text-muted-foreground mt-2">${escapeHtml(alt)}</figcaption>` : ''}
        </figure>`
      },
    },
    marks: {
      link: ({ children, value }) => {
        const v = value as { href: string; blank?: boolean }
        const href = /^javascript:/i.test(v.href) ? '#' : v.href
        const safeHref = escapeHtml(href)
        const target = v.blank ? ' target="_blank"' : ''
        const rel = v.blank ? ' rel="noopener noreferrer"' : ''
        return `<a href="${safeHref}"${target}${rel}>${children}</a>`
      },
    },
  },
})
---

<div class="prose prose-invert max-w-none" set:html={html} />
