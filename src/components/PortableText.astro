---
import { toHTML } from '@portabletext/to-html'
import imageUrlBuilder from '@sanity/image-url'
import { client } from '@/lib/sanity/client'
import { processBodyWithHighlighting } from '@/lib/sanity/process-body.server'
import type { Post } from '@/lib/sanity/types'

interface Props {
  value: Post['body']
}

const { value } = Astro.props
const builder = imageUrlBuilder(client)

const processedBlocks = await processBodyWithHighlighting(value)

const html = toHTML(processedBlocks as Parameters<typeof toHTML>[0], {
  components: {
    types: {
      code: ({ value }) => {
        const v = value as Record<string, unknown>
        if (v.highlightedHtml) {
          return `<div class="not-prose code-block my-6">${v.highlightedHtml}</div>`
        }
        return `<pre><code>${String(v.code ?? '')}</code></pre>`
      },
      callout: ({ value }) => {
        const v = value as { text?: string; tone?: string }
        const tone = v.tone ?? 'info'
        return `<div class="callout callout-${tone} not-prose my-6 p-4 rounded-lg border-l-4" role="note"><p>${v.text ?? ''}</p></div>`
      },
      image: ({ value }) => {
        const v = value as Record<string, unknown>
        if (!v.asset) return ''
        const src400 = builder.image(v).width(400).auto('format').url()
        const src800 = builder.image(v).width(800).auto('format').url()
        const src1200 = builder.image(v).width(1200).auto('format').url()
        const alt = String(v.alt ?? '')
        return `<figure class="my-8">
          <picture>
            <source srcset="${src800} 800w, ${src1200} 1200w" sizes="(max-width: 800px) 100vw, 800px" />
            <img src="${src400}" alt="${alt.replace(/"/g, '&quot;')}" loading="lazy" decoding="async" class="rounded-lg w-full" />
          </picture>
          ${alt ? `<figcaption class="text-sm text-center text-muted-foreground mt-2">${alt}</figcaption>` : ''}
        </figure>`
      },
    },
    marks: {
      link: ({ children, value }) => {
        const v = value as { href: string; blank?: boolean }
        const target = v.blank ? ' target="_blank"' : ''
        const rel = v.blank ? ' rel="noopener noreferrer"' : ''
        return `<a href="${v.href}"${target}${rel}>${children}</a>`
      },
    },
  },
})
---

<div class="prose prose-invert max-w-none" set:html={html} />
