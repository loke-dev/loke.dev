---
const year = new Date().getFullYear()

const exploreLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
  { href: '/changelog', label: 'Changelog' },
]

const socialLinks = [
  {
    href: 'https://github.com/loke-dev',
    label: 'GitHub',
    description: 'Code & experiments',
  },
  {
    href: 'https://twitter.com/loke_dev',
    label: 'Twitter',
    description: 'Shorter thoughts',
  },
]

const feedsLinks = [
  { href: '/rss.xml', label: 'RSS feed', external: false },
  {
    href: 'https://github.com/loke-dev/loke.dev',
    label: 'Site source',
    external: true,
  },
] as const
---

<footer class="w-full border-t border-border/80 bg-muted/30">
  <div class="container mx-auto max-w-6xl px-4 py-14 md:px-8 md:py-20">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-10">
      <div class="lg:col-span-2">
        <a href="/" class="inline-block text-2xl font-bold tracking-tight text-foreground">
          loke.dev
        </a>
        <p class="mt-4 max-w-md text-base leading-relaxed text-muted-foreground">
          Web development, notes, and side projects. Built with Astro, Sanity, and too much
          coffee.
        </p>
        <p class="mt-6 text-sm text-muted-foreground">
          © {year} Loke. All rights reserved.
        </p>
      </div>

      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Explore</h2>
        <ul class="mt-5 space-y-3">
          {exploreLinks.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-base font-medium text-foreground underline-offset-4 transition-colors hover:text-accent hover:underline"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Connect</h2>
        <ul class="mt-5 space-y-4">
          {socialLinks.map((item) => (
            <li>
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group block"
              >
                <span class="text-base font-medium text-foreground underline-offset-4 transition-colors group-hover:text-accent group-hover:underline">
                  {item.label}
                </span>
                <span class="mt-0.5 block text-sm text-muted-foreground">{item.description}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-6 border-t border-border/60 pt-10 md:flex-row md:items-center md:justify-between">
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Feeds and source">
        {feedsLinks.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="text-sm font-medium text-muted-foreground underline-offset-4 transition-colors hover:text-accent hover:underline"
          >
            {item.label}
          </a>
        ))}
      </nav>
      <p class="text-sm text-muted-foreground">
        Thanks for stopping by —{' '}
        <a href="/contact" class="font-medium text-foreground underline-offset-4 hover:text-accent hover:underline">
          say hello
        </a>
        {''} if anything resonated.
      </p>
    </div>
  </div>
</footer>
