---
import BlogPostCard from '@/components/BlogPostCard.astro'
import Pagination from '@/components/Pagination.astro'
import type { BlogPage, PostListItem } from '@/utils/sanity.queries'

interface Props {
  page: BlogPage
  posts: PostListItem[]
  currentPage: number
  totalPages: number
}

const { page, posts, currentPage, totalPages } = Astro.props
---

<div class="container mx-auto max-w-5xl px-4 py-12">
  <header class="mb-10">
    <h1 class="text-4xl font-bold tracking-tight">{page.title}</h1>
    {page.description && (
      <p class="mt-3 text-lg text-muted-foreground">{page.description}</p>
    )}
  </header>

  {posts.length === 0 ? (
    <div class="rounded-lg border p-8 text-center">
      <h2 class="mb-2 text-xl font-semibold">
        {page.emptyStateTitle ?? 'No posts yet'}
      </h2>
      <p class="text-muted-foreground">
        {page.emptyStateDescription ?? 'Check back soon for new articles!'}
      </p>
    </div>
  ) : (
    <>
      <div class="grid gap-6 sm:grid-cols-2">
        {posts.map((post) => (
          <BlogPostCard post={post} />
        ))}
      </div>

      <Pagination currentPage={currentPage} totalPages={totalPages} />
    </>
  )}
</div>
