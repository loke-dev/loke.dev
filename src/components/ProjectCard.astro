---
import type { Project } from '@/lib/sanity/types'
import { getSanityImageUrl, getSanityImageSrcSet } from '@/lib/sanity/helpers'

interface Props {
  project: Project
  featured?: boolean
}

const { project, featured = false } = Astro.props

const width = featured ? 800 : 500
const height = featured ? 450 : 375
const listQuality = 72
const srcWidths = [Math.round(width / 2), width, Math.round(width * 1.5)]
const imageUrl = getSanityImageUrl(project.image, width, height, listQuality)
const srcSet = getSanityImageSrcSet(
  project.image,
  srcWidths,
  height,
  listQuality,
  width
)
---

<article class={`surface-interactive overflow-hidden rounded-xl border border-border/80 bg-card transition-[transform,border-color,box-shadow] hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-[0_20px_50px_-28px_oklch(72%_0.16_70/0.28)] ${featured ? 'flex flex-col md:flex-row w-full' : 'flex flex-col h-full'}`}>
  {imageUrl && (
    <div class={`relative w-full overflow-hidden ${featured ? 'md:w-1/3 md:h-auto aspect-[16/9] md:aspect-auto' : 'aspect-[4/3]'}`}>
      <img
        src={imageUrl}
        srcset={srcSet || undefined}
        sizes={featured ? '(min-width: 1024px) 33vw, 100vw' : '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw'}
        alt={project.image?.alt || project.title}
        loading="lazy"
        decoding="async"
        width={width}
        height={height}
        class="h-full w-full object-cover object-center"
      />
    </div>
  )}
  {!imageUrl && (
    <div class={`relative overflow-hidden bg-gradient-to-br from-accent/20 via-secondary to-background ${featured ? 'min-h-48 md:w-1/3 md:min-h-0' : 'aspect-[4/3]'}`}>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_25%,oklch(72%_0.18_70/0.28),transparent_34%),radial-gradient(circle_at_78%_75%,oklch(60%_0.12_250/0.22),transparent_38%)]"></div>
      <div class="relative flex h-full items-end p-6">
        <span class="rounded-full border border-accent/35 bg-background/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-foreground backdrop-blur">
          Project note
        </span>
      </div>
    </div>
  )}

  <div class={`flex flex-col ${featured ? 'md:w-2/3' : 'w-full'}`}>
    <div class="p-6 pb-2">
      <h3 class={`font-semibold ${featured ? 'text-xl md:text-2xl' : 'text-lg'}`}>
        {project.title}
      </h3>
    </div>

    <div class="px-6 pb-4 flex-1">
      <p class={`mb-4 text-muted-foreground ${featured ? 'text-base' : 'text-sm'}`}>
        {project.description}
      </p>

      {project.technologies?.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {project.technologies.map((tech) => (
            <span class="rounded-full bg-secondary px-2.5 py-0.5 text-xs font-medium text-secondary-foreground">
              {tech}
            </span>
          ))}
        </div>
      )}
    </div>

    <div class="flex gap-3 px-6 pb-6 mt-auto">
      {project.url && (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Visit ${project.title} (opens in new tab)`}
          class="inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          Visit Project
        </a>
      )}
      {project.github && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${project.title} on GitHub (opens in new tab)`}
          class="inline-flex items-center justify-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-secondary"
        >
          GitHub
        </a>
      )}
    </div>
  </div>
</article>
