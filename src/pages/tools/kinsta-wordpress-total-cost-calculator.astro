---
export const prerender = true

import BaseLayout from '@/layouts/BaseLayout.astro'
import PageIntro from '@/components/PageIntro.astro'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', CACHE_CONTROL.staticPage)

const pageUrl = `${SITE_DOMAIN}/tools/kinsta-wordpress-total-cost-calculator`
const description =
  'Estimate Kinsta WordPress hosting with editable monthly and annual prices, add-ons, VAT, migration work, administration, and a self-managed alternative.'
const calculatorSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Kinsta WordPress total cost calculator',
  description,
  url: pageUrl,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
}
---

<BaseLayout
  title="Kinsta WordPress total cost calculator"
  description={description}
  url={pageUrl}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(calculatorSchema)}
  />

  <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <PageIntro
      eyebrow="Free calculator"
      title="Price managed WordPress beyond the plan card."
      description="Compare monthly and annual Kinsta references, common add-ons, tax treatment, migration work, and ongoing administration with an editable server alternative."
    />

    <aside class="mt-8 max-w-3xl rounded-xl border border-accent/25 bg-accent/10 p-5 text-sm leading-relaxed text-muted-foreground">
      <strong class="text-foreground">Pricing reference:</strong>
      on 24 July 2026, Kinsta’s USD pricing page showed its Single 20GB
      bandwidth plan at $35 monthly or $350 annually. It listed additional
      WordPress sites at $30 per month, 20GB storage blocks at $20 per month,
      premium staging environments at $20 per month, and automatic updates at
      $3 per environment per month. Verify the
      <a
        class="font-medium text-foreground underline hover:text-accent"
        href="https://kinsta.com/pricing/"
        target="_blank"
        rel="noopener"
      >current plan, allowance, and checkout</a>
      before buying. All prices are editable. This calculator stores no input.
    </aside>

    <form
      id="kinsta-cost-calculator"
      class="mt-12 grid items-start gap-8 lg:grid-cols-[minmax(0,1.08fr)_minmax(20rem,0.92fr)]"
    >
      <div class="space-y-8">
        <fieldset class="rounded-2xl border border-border/80 bg-card p-6 md:p-8">
          <legend class="px-2 text-xl font-bold">Plan and billing</legend>
          <div class="mt-4 grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2 text-sm font-medium">
              Monthly plan price, USD
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="monthlyPlan"
                min="0"
                step="0.01"
                value="35"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Annual plan bill, USD
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="annualPlan"
                min="0"
                step="0.01"
                value="350"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Effective VAT or sales tax, %
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="taxRate"
                min="0"
                step="0.1"
                value="0"
                inputmode="decimal"
              />
              <span class="text-xs font-normal leading-relaxed text-muted-foreground">
                Use the amount your organization cannot reclaim.
              </span>
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Value of time, USD/hour
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="hourly"
                min="0"
                step="5"
                value="75"
                inputmode="decimal"
              />
            </label>
          </div>
        </fieldset>

        <fieldset class="rounded-2xl border border-border/80 bg-card p-6 md:p-8">
          <legend class="px-2 text-xl font-bold">Kinsta add-ons</legend>
          <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
            Enter only add-ons you expect to keep. The plan price and included
            allowances still need to match the site’s measured use.
          </p>
          <div class="mt-6 grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2 text-sm font-medium">
              Additional WordPress sites
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="extraSites"
                min="0"
                step="1"
                value="0"
                inputmode="numeric"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Price per additional site/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="extraSitePrice"
                min="0"
                step="0.01"
                value="30"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Extra 20GB storage blocks
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="storageBlocks"
                min="0"
                step="1"
                value="0"
                inputmode="numeric"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Price per storage block/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="storagePrice"
                min="0"
                step="0.01"
                value="20"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Premium staging environments
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="stagingEnvironments"
                min="0"
                step="1"
                value="0"
                inputmode="numeric"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Price per staging environment/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="stagingPrice"
                min="0"
                step="0.01"
                value="20"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Automatic-update environments
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="updateEnvironments"
                min="0"
                step="1"
                value="0"
                inputmode="numeric"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Price per update environment/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="updatePrice"
                min="0"
                step="0.01"
                value="3"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Other Kinsta add-ons/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="otherAddons"
                min="0"
                step="0.01"
                value="0"
                inputmode="decimal"
              />
            </label>
          </div>
        </fieldset>

        <fieldset class="rounded-2xl border border-border/80 bg-card p-6 md:p-8">
          <legend class="px-2 text-xl font-bold">Work and alternative</legend>
          <div class="mt-4 grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2 text-sm font-medium">
              Kinsta migration/setup hours
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="kinstaSetup"
                min="0"
                step="0.5"
                value="4"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Kinsta admin hours/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="kinstaAdmin"
                min="0"
                step="0.25"
                value="1"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Alternative infrastructure/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="alternativeInfra"
                min="0"
                step="0.01"
                value="25"
                inputmode="decimal"
              />
              <span class="text-xs font-normal leading-relaxed text-muted-foreground">
                Include server, backups, CDN, monitoring, and paid security tools.
              </span>
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Alternative setup hours
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="alternativeSetup"
                min="0"
                step="0.5"
                value="8"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Alternative admin hours/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="alternativeAdmin"
                min="0"
                step="0.25"
                value="3"
                inputmode="decimal"
              />
            </label>
          </div>
        </fieldset>
      </div>

      <section
        class="rounded-2xl border border-accent/30 bg-[linear-gradient(145deg,color-mix(in_oklab,var(--card)_92%,var(--accent)),var(--card))] p-6 lg:sticky lg:top-6 lg:p-8"
        aria-live="polite"
        aria-labelledby="result-title"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
          Estimate
        </p>
        <h2 id="result-title" class="mt-2 text-2xl font-bold">
          First-year total
        </h2>

        <dl class="mt-7 space-y-5">
          <div class="border-b border-border/70 pb-5">
            <dt class="text-sm text-muted-foreground">Kinsta, annual plan</dt>
            <dd id="annual-result" class="mt-1 text-2xl font-bold tabular-nums">
              $1,550.00
            </dd>
            <dd id="annual-detail" class="mt-1 text-sm text-muted-foreground">
              $350.00 subscription and add-ons + $1,200.00 work.
            </dd>
          </div>
          <div class="border-b border-border/70 pb-5">
            <dt class="text-sm text-muted-foreground">Kinsta, monthly plan</dt>
            <dd id="monthly-result" class="mt-1 text-2xl font-bold tabular-nums">
              $1,620.00
            </dd>
            <dd id="monthly-detail" class="mt-1 text-sm text-muted-foreground">
              $420.00 subscription and add-ons + $1,200.00 work.
            </dd>
          </div>
          <div>
            <dt class="text-sm text-muted-foreground">Self-managed alternative</dt>
            <dd id="alternative-result" class="mt-1 text-2xl font-bold tabular-nums">
              $3,600.00
            </dd>
            <dd id="alternative-detail" class="mt-1 text-sm text-muted-foreground">
              $300.00 infrastructure + $3,300.00 work.
            </dd>
          </div>
        </dl>

        <div class="mt-7 rounded-xl border border-border/80 bg-background/50 p-4">
          <p id="billing-result" class="text-sm font-medium leading-relaxed">
            Annual billing saves $70.00 before tax for these plan inputs.
          </p>
          <p id="comparison-result" class="mt-3 text-sm leading-relaxed text-muted-foreground">
            The annual Kinsta estimate is $2,050.00 lower in the first year.
          </p>
          <p id="break-even-result" class="mt-3 text-xs leading-relaxed text-muted-foreground">
            The alternative reaches the Kinsta total at 0.7 admin hours per month. Compare that threshold with a work log.
          </p>
        </div>

        <div class="mt-7 flex flex-col gap-3">
          <a
            class="interactive-button inline-flex justify-center rounded-md bg-primary px-4 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90"
            href="/go/kinsta?from=wordpress-total-cost-calculator"
          >
            Check Kinsta WordPress plans →
          </a>
        </div>
        <p class="mt-4 text-xs leading-relaxed text-muted-foreground">
          The Kinsta link is currently a direct tracked link and earns no
          commission. See the <a class="underline hover:text-foreground" href="/affiliate-disclosure">disclosure</a>.
        </p>
      </section>
    </form>

    <section class="mt-16 max-w-3xl space-y-5">
      <h2 class="text-2xl font-bold">What belongs outside the calculator</h2>
      <p class="leading-relaxed text-muted-foreground">
        Match the plan to measured server bandwidth or visits, storage, CDN
        use, WordPress installs, backup retention, and traffic growth. An annual
        discount is not useful when the selected plan is too small.
      </p>
      <p class="leading-relaxed text-muted-foreground">
        Test staging, restore, deployment, logs, database access, caching,
        outbound email, scheduled jobs, plugin compatibility, and support with
        a representative site. Record the time saved instead of assigning all
        server work a guessed value.
      </p>
      <p class="leading-relaxed text-muted-foreground">
        A Swedish organization should check the chosen data center, access-log
        processing, backups, subprocessors, contract terms, invoice currency,
        and VAT treatment. A European data center does not settle the entire
        data-processing review.
      </p>
    </section>
  </div>
</BaseLayout>

<script>
  function setupKinstaCostCalculator() {
    const form = document.querySelector<HTMLFormElement>(
      '#kinsta-cost-calculator'
    )
    if (!form || form.dataset.ready === 'true') return
    form.dataset.ready = 'true'

    const currency = new Intl.NumberFormat('en-SE', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    })
    const number = new Intl.NumberFormat('en-SE', {
      maximumFractionDigits: 1,
    })
    const getValue = (name: string) => {
      const input = form.elements.namedItem(name)
      if (!(input instanceof HTMLInputElement)) return 0
      return Math.max(0, Number(input.value) || 0)
    }
    const getCount = (name: string) => Math.ceil(getValue(name))
    const setText = (id: string, value: string) => {
      const element = document.querySelector<HTMLElement>(`#${id}`)
      if (element) element.textContent = value
    }

    const calculate = () => {
      const taxMultiplier = 1 + getValue('taxRate') / 100
      const hourly = getValue('hourly')
      const monthlyAddons =
        getCount('extraSites') * getValue('extraSitePrice') +
        getCount('storageBlocks') * getValue('storagePrice') +
        getCount('stagingEnvironments') * getValue('stagingPrice') +
        getCount('updateEnvironments') * getValue('updatePrice') +
        getValue('otherAddons')

      const annualPlanBeforeTax = getValue('annualPlan') + monthlyAddons * 12
      const monthlyPlanBeforeTax =
        (getValue('monthlyPlan') + monthlyAddons) * 12
      const annualSubscription = annualPlanBeforeTax * taxMultiplier
      const monthlySubscription = monthlyPlanBeforeTax * taxMultiplier
      const kinstaWork =
        (getValue('kinstaSetup') + getValue('kinstaAdmin') * 12) * hourly
      const annualKinstaTotal = annualSubscription + kinstaWork
      const monthlyKinstaTotal = monthlySubscription + kinstaWork

      const alternativeInfrastructure =
        getValue('alternativeInfra') * 12 * taxMultiplier
      const alternativeWork =
        (getValue('alternativeSetup') +
          getValue('alternativeAdmin') * 12) *
        hourly
      const alternativeTotal = alternativeInfrastructure + alternativeWork

      setText('annual-result', currency.format(annualKinstaTotal))
      setText(
        'annual-detail',
        `${currency.format(annualSubscription)} subscription and add-ons + ${currency.format(kinstaWork)} work.`
      )
      setText('monthly-result', currency.format(monthlyKinstaTotal))
      setText(
        'monthly-detail',
        `${currency.format(monthlySubscription)} subscription and add-ons + ${currency.format(kinstaWork)} work.`
      )
      setText('alternative-result', currency.format(alternativeTotal))
      setText(
        'alternative-detail',
        `${currency.format(alternativeInfrastructure)} infrastructure + ${currency.format(alternativeWork)} work.`
      )

      const billingDifference = monthlySubscription - annualSubscription
      if (Math.abs(billingDifference) < 0.01) {
        setText(
          'billing-result',
          'Monthly and annual billing are equal for the entered prices.'
        )
      } else if (billingDifference > 0) {
        setText(
          'billing-result',
          `Annual billing saves ${currency.format(billingDifference)} after the entered tax treatment.`
        )
      } else {
        setText(
          'billing-result',
          `Monthly billing is ${currency.format(Math.abs(billingDifference))} lower for the entered prices. Check that both inputs cover the same term and promotion.`
        )
      }

      const comparisonDifference = Math.abs(
        annualKinstaTotal - alternativeTotal
      )
      if (comparisonDifference < 0.01) {
        setText(
          'comparison-result',
          'The first-year annual Kinsta and alternative estimates are equal.'
        )
      } else if (annualKinstaTotal < alternativeTotal) {
        setText(
          'comparison-result',
          `The annual Kinsta estimate is ${currency.format(comparisonDifference)} lower in the first year.`
        )
      } else {
        setText(
          'comparison-result',
          `The self-managed estimate is ${currency.format(comparisonDifference)} lower in the first year. Decide whether measured support, recovery, and admin savings justify the difference.`
        )
      }

      if (hourly === 0) {
        setText(
          'break-even-result',
          'Enter a non-zero hourly value to calculate the administration break-even point.'
        )
        return
      }

      const fixedAlternative =
        alternativeInfrastructure + getValue('alternativeSetup') * hourly
      const fixedKinsta =
        annualSubscription + getValue('kinstaSetup') * hourly
      const breakEvenAlternativeAdmin =
        getValue('kinstaAdmin') +
        (fixedKinsta - fixedAlternative) / (12 * hourly)
      setText(
        'break-even-result',
        breakEvenAlternativeAdmin <= 0
          ? 'Kinsta is already lower before counting monthly administration at these inputs.'
          : `The alternative reaches the Kinsta total at ${number.format(breakEvenAlternativeAdmin)} admin hours per month. Compare that threshold with a work log.`
      )
    }

    form.addEventListener('input', calculate)
    form.addEventListener('change', calculate)
    calculate()
  }

  setupKinstaCostCalculator()
  document.addEventListener('astro:after-swap', setupKinstaCostCalculator)
</script>
