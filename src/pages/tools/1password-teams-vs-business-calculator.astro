---
export const prerender = true

import BaseLayout from '@/layouts/BaseLayout.astro'
import PageIntro from '@/components/PageIntro.astro'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', CACHE_CONTROL.staticPage)

const pageUrl = `${SITE_DOMAIN}/tools/1password-teams-vs-business-calculator`
const description =
  'Compare 1Password Teams Starter Pack and Business using editable prices, team and guest counts, feature requirements, and first-year rollout time.'
const calculatorSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '1Password Teams vs Business calculator',
  description,
  url: pageUrl,
  applicationCategory: 'SecurityApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
}
---

<BaseLayout
  title="1Password Teams vs Business calculator"
  description={description}
  url={pageUrl}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(calculatorSchema)}
  />

  <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <PageIntro
      eyebrow="Free calculator"
      title="Price the 1Password plan your team can actually use."
      description="Compare editable subscription prices, the 10-member Teams reference, Business-only requirements, guest counts, and the time needed for a real rollout."
    />

    <aside class="mt-8 max-w-3xl rounded-xl border border-accent/25 bg-accent/10 p-5 text-sm leading-relaxed text-muted-foreground">
      <strong class="text-foreground">Pricing reference:</strong>
      on 24 July 2026, 1Password’s USD pricing card showed Teams Starter Pack
      at $24.95 per month for 10 members and Business at $8.99 per member per
      month, both with annual billing. Some explanatory copy still showed an
      older Teams amount. Verify the
      <a
        class="font-medium text-foreground underline hover:text-accent"
        href="https://1password.com/pricing/password-manager"
        target="_blank"
        rel="noopener"
      >live price and checkout</a>
      for your region. Every price field below is editable. This independent
      calculator stores no input and is not a security assessment.
    </aside>

    <form
      id="password-plan-calculator"
      class="mt-12 grid items-start gap-8 lg:grid-cols-[minmax(0,1.08fr)_minmax(20rem,0.92fr)]"
    >
      <div class="space-y-8">
        <fieldset class="rounded-2xl border border-border/80 bg-card p-6 md:p-8">
          <legend class="px-2 text-xl font-bold">People and prices</legend>
          <div class="mt-4 grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2 text-sm font-medium">
              Team members
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="members"
                min="1"
                step="1"
                value="8"
                inputmode="numeric"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Limited-access guests
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="guests"
                min="0"
                step="1"
                value="2"
                inputmode="numeric"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Teams base price, USD/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="teamsBase"
                min="0"
                step="0.01"
                value="24.95"
                inputmode="decimal"
              />
              <span class="text-xs font-normal leading-relaxed text-muted-foreground">
                Includes 10 members in the current reference.
              </span>
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Extra Teams member, USD/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="teamsExtra"
                min="0"
                step="0.01"
                value="0"
                inputmode="decimal"
              />
              <span class="text-xs font-normal leading-relaxed text-muted-foreground">
                Leave at zero until support gives you a quote.
              </span>
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Business price per member, USD/month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="businessSeat"
                min="0"
                step="0.01"
                value="8.99"
                inputmode="decimal"
              />
            </label>
          </div>
        </fieldset>

        <fieldset class="rounded-2xl border border-border/80 bg-card p-6 md:p-8">
          <legend class="px-2 text-xl font-bold">Requirements</legend>
          <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
            Price cannot make Teams suitable when a required control is
            Business-only. Confirm every feature against the current plan table.
          </p>
          <div class="mt-6 grid gap-4">
            <label class="flex gap-3 rounded-lg border border-border/70 p-4">
              <input
                class="mt-1 size-4"
                type="checkbox"
                name="customGroups"
              />
              <span>
                <strong class="block">Custom groups and delegated access</strong>
                <span class="mt-1 block text-sm leading-relaxed text-muted-foreground">
                  Organize access beyond the built-in team groups.
                </span>
              </span>
            </label>
            <label class="flex gap-3 rounded-lg border border-border/70 p-4">
              <input
                class="mt-1 size-4"
                type="checkbox"
                name="identityProvider"
              />
              <span>
                <strong class="block">Identity provider or automated provisioning</strong>
                <span class="mt-1 block text-sm leading-relaxed text-muted-foreground">
                  Use SSO or provision users and groups from an identity system.
                </span>
              </span>
            </label>
            <label class="flex gap-3 rounded-lg border border-border/70 p-4">
              <input
                class="mt-1 size-4"
                type="checkbox"
                name="reporting"
              />
              <span>
                <strong class="block">Detailed reports, activity data, or SIEM export</strong>
                <span class="mt-1 block text-sm leading-relaxed text-muted-foreground">
                  Keep a stronger audit trail or stream security events.
                </span>
              </span>
            </label>
            <label class="flex gap-3 rounded-lg border border-border/70 p-4">
              <input
                class="mt-1 size-4"
                type="checkbox"
                name="policies"
              />
              <span>
                <strong class="block">Enforced organization policies</strong>
                <span class="mt-1 block text-sm leading-relaxed text-muted-foreground">
                  Apply administrative or security policy beyond basic vault permissions.
                </span>
              </span>
            </label>
          </div>
        </fieldset>

        <fieldset class="rounded-2xl border border-border/80 bg-card p-6 md:p-8">
          <legend class="px-2 text-xl font-bold">Rollout time</legend>
          <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
            These costs apply to either plan. Include them so the first-year
            budget is not just the subscription invoice.
          </p>
          <div class="mt-6 grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2 text-sm font-medium">
              Onboarding hours per member
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="onboardingHours"
                min="0"
                step="0.25"
                value="0.75"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Initial admin setup hours
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="setupHours"
                min="0"
                step="0.5"
                value="4"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Ongoing admin hours per month
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="adminHours"
                min="0"
                step="0.25"
                value="1"
                inputmode="decimal"
              />
            </label>
            <label class="grid gap-2 text-sm font-medium">
              Value of time, USD/hour
              <input
                class="rounded-lg border border-input bg-background px-3 py-2.5 text-base"
                type="number"
                name="hourly"
                min="0"
                step="5"
                value="50"
                inputmode="decimal"
              />
            </label>
          </div>
        </fieldset>
      </div>

      <section
        class="rounded-2xl border border-accent/30 bg-[linear-gradient(145deg,color-mix(in_oklab,var(--card)_92%,var(--accent)),var(--card))] p-6 lg:sticky lg:top-6 lg:p-8"
        aria-live="polite"
        aria-labelledby="result-title"
      >
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent">
          Estimate
        </p>
        <h2 id="result-title" class="mt-2 text-2xl font-bold">
          First-year comparison
        </h2>

        <dl class="mt-7 space-y-5">
          <div class="border-b border-border/70 pb-5">
            <dt class="text-sm text-muted-foreground">Teams Starter Pack</dt>
            <dd id="teams-result" class="mt-1 text-2xl font-bold tabular-nums">
              $24.95/month
            </dd>
            <dd id="teams-detail" class="mt-1 text-sm text-muted-foreground">
              $1,399.40 first year including rollout time.
            </dd>
          </div>
          <div class="border-b border-border/70 pb-5">
            <dt class="text-sm text-muted-foreground">Business</dt>
            <dd id="business-result" class="mt-1 text-2xl font-bold tabular-nums">
              $71.92/month
            </dd>
            <dd id="business-detail" class="mt-1 text-sm text-muted-foreground">
              $1,963.04 first year including rollout time.
            </dd>
          </div>
          <div>
            <dt class="text-sm text-muted-foreground">Shared rollout estimate</dt>
            <dd id="rollout-result" class="mt-1 text-2xl font-bold tabular-nums">
              $1,100.00
            </dd>
            <dd id="rollout-detail" class="mt-1 text-sm text-muted-foreground">
              $500.00 initial work + $600.00 first-year administration.
            </dd>
          </div>
        </dl>

        <div class="mt-7 rounded-xl border border-border/80 bg-background/50 p-4">
          <p id="recommendation-result" class="text-sm font-medium leading-relaxed">
            Teams is $563.64 lower in the first year for these inputs, and no
            Business-only requirement is selected.
          </p>
          <p id="guest-result" class="mt-3 text-xs leading-relaxed text-muted-foreground">
            Two guests fit within both current included-guest references.
          </p>
        </div>

        <div
          id="quote-panel"
          class="mt-4 hidden rounded-xl border border-amber-400/35 bg-amber-400/10 p-4"
        >
          <p id="quote-result" class="text-sm leading-relaxed">
            Ask support for the extra-member price before comparing totals.
          </p>
        </div>

        <div class="mt-7 flex flex-col gap-3">
          <a
            class="interactive-button inline-flex justify-center rounded-md bg-primary px-4 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90"
            href="/go/1password?from=teams-business-calculator"
          >
            Check 1Password plans →
          </a>
        </div>
        <p class="mt-4 text-xs leading-relaxed text-muted-foreground">
          The 1Password link is currently a direct tracked link and earns no
          commission. See the <a class="underline hover:text-foreground" href="/affiliate-disclosure">disclosure</a>.
        </p>
      </section>
    </form>

    <section class="mt-16 max-w-3xl space-y-5">
      <h2 class="text-2xl font-bold">What the estimate does not decide</h2>
      <p class="leading-relaxed text-muted-foreground">
        A password manager rollout needs vault ownership, recovery owners,
        emergency access, offboarding, device policy, phishing-resistant
        authentication where supported, and a rule for credentials that belong
        in a deployment system instead of a human vault. Price does not prove
        those controls exist.
      </p>
      <p class="leading-relaxed text-muted-foreground">
        Developer tools are available across the current team plans, but plan
        limits and administrative controls can differ. Test the CLI, SSH agent,
        service accounts, CI integration, and recovery flow with a non-production
        vault before moving live credentials.
      </p>
      <p class="leading-relaxed text-muted-foreground">
        A Swedish organization can create an account in the European region,
        which 1Password says is billed in EUR with secure data hosted in the EU.
        Confirm the region before creating the account because moving regions
        requires a migration. Check the real invoice for VAT and accounting.
      </p>
    </section>
  </div>
</BaseLayout>

<script>
  function setupPasswordPlanCalculator() {
    const form = document.querySelector<HTMLFormElement>(
      '#password-plan-calculator'
    )
    if (!form || form.dataset.ready === 'true') return
    form.dataset.ready = 'true'

    const currency = new Intl.NumberFormat('en-SE', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    })
    const number = new Intl.NumberFormat('en-SE', {
      maximumFractionDigits: 1,
    })
    const getValue = (name: string, minimum = 0) => {
      const input = form.elements.namedItem(name)
      if (!(input instanceof HTMLInputElement)) return minimum
      return Math.max(minimum, Number(input.value) || 0)
    }
    const isChecked = (name: string) => {
      const input = form.elements.namedItem(name)
      return input instanceof HTMLInputElement && input.checked
    }
    const setText = (id: string, value: string) => {
      const element = document.querySelector<HTMLElement>(`#${id}`)
      if (element) element.textContent = value
    }

    const calculate = () => {
      const members = Math.ceil(getValue('members', 1))
      const guests = Math.ceil(getValue('guests'))
      const teamsBase = getValue('teamsBase')
      const teamsExtra = getValue('teamsExtra')
      const businessSeat = getValue('businessSeat')
      const extraMembers = Math.max(0, members - 10)
      const teamsWithinPublishedRange = members <= 20
      const teamsNeedsQuote = extraMembers > 0 && teamsExtra === 0
      const teamsMonthly =
        teamsWithinPublishedRange && !teamsNeedsQuote
          ? teamsBase + extraMembers * teamsExtra
          : null
      const businessMonthly = members * businessSeat

      const initialHours =
        members * getValue('onboardingHours') + getValue('setupHours')
      const initialCost = initialHours * getValue('hourly')
      const annualAdminCost =
        getValue('adminHours') * getValue('hourly') * 12
      const sharedRollout = initialCost + annualAdminCost
      const teamsFirstYear =
        teamsMonthly === null ? null : teamsMonthly * 12 + sharedRollout
      const businessFirstYear = businessMonthly * 12 + sharedRollout

      const businessRequirements = [
        isChecked('customGroups'),
        isChecked('identityProvider'),
        isChecked('reporting'),
        isChecked('policies'),
      ].filter(Boolean).length

      setText(
        'teams-result',
        teamsMonthly === null
          ? 'Quote required'
          : `${currency.format(teamsMonthly)}/month`
      )
      setText(
        'teams-detail',
        teamsFirstYear === null
          ? teamsWithinPublishedRange
            ? `${extraMembers} extra ${extraMembers === 1 ? 'member needs' : 'members need'} a support quote.`
            : 'Above the current 20-member Teams pricing-card reference.'
          : `${currency.format(teamsFirstYear)} first year including rollout time.`
      )
      setText(
        'business-result',
        `${currency.format(businessMonthly)}/month`
      )
      setText(
        'business-detail',
        `${currency.format(businessFirstYear)} first year including rollout time.`
      )
      setText('rollout-result', currency.format(sharedRollout))
      setText(
        'rollout-detail',
        `${currency.format(initialCost)} initial work (${number.format(initialHours)} hours) + ${currency.format(annualAdminCost)} first-year administration.`
      )

      if (guests <= 5) {
        setText(
          'guest-result',
          `${number.format(guests)} ${guests === 1 ? 'guest fits' : 'guests fit'} within both current included-guest references.`
        )
      } else if (guests <= 20) {
        setText(
          'guest-result',
          `${number.format(guests)} guests exceed the Teams reference of 5 but fit within the Business reference of 20. Confirm guest pricing and access limits.`
        )
      } else {
        setText(
          'guest-result',
          `${number.format(guests)} guests exceed both included references. Ask for additional-guest pricing and confirm that one-vault guest access fits the workflow.`
        )
      }

      const quotePanel = document.querySelector<HTMLElement>('#quote-panel')
      const showQuote = teamsMonthly === null
      quotePanel?.classList.toggle('hidden', !showQuote)
      if (showQuote) {
        if (!teamsWithinPublishedRange) {
          setText(
            'quote-result',
            'The current pricing card describes at most 10 additional Teams seats. Treat Business as the priced option and ask sales whether another Teams arrangement exists.'
          )
        } else {
          const parityExtra =
            extraMembers > 0
              ? Math.max(0, (businessMonthly - teamsBase) / extraMembers)
              : 0
          setText(
            'quote-result',
            `Ask support for the extra-member price. Teams matches the entered Business subscription at ${currency.format(parityExtra)} per extra member per month.`
          )
        }
      }

      if (businessRequirements > 0) {
        setText(
          'recommendation-result',
          `Business is the viable reference because ${businessRequirements} selected ${businessRequirements === 1 ? 'requirement points' : 'requirements point'} to Business-only controls. Verify the exact feature in your quote.`
        )
        return
      }
      if (teamsFirstYear === null) {
        setText(
          'recommendation-result',
          teamsWithinPublishedRange
            ? 'The Teams total is unknown until you enter the extra-member quote. No Business-only requirement is selected.'
            : 'The team is above the current Teams pricing-card range. Use the Business total as the priced reference and ask sales about alternatives.'
        )
        return
      }

      const difference = Math.abs(teamsFirstYear - businessFirstYear)
      if (difference < 0.01) {
        setText(
          'recommendation-result',
          'The first-year totals are equal for these inputs. Decide from required controls, guest access, support, and future team size.'
        )
      } else if (teamsFirstYear < businessFirstYear) {
        setText(
          'recommendation-result',
          `Teams is ${currency.format(difference)} lower in the first year for these inputs, and no Business-only requirement is selected.`
        )
      } else {
        setText(
          'recommendation-result',
          `Business is ${currency.format(difference)} lower in the first year for these inputs. Confirm that the entered Teams quote and Business seat price use the same billing term.`
        )
      }
    }

    form.addEventListener('input', calculate)
    form.addEventListener('change', calculate)
    calculate()
  }

  setupPasswordPlanCalculator()
  document.addEventListener('astro:after-swap', setupPasswordPlanCalculator)
</script>
