---
import profileAvif256 from '@/assets/loke-clay-256.avif'
import profileAvif512 from '@/assets/loke-clay-512.avif'
import profilePng512 from '@/assets/loke-clay-512.png'
import profileWebp256 from '@/assets/loke-clay-256.webp'
import profileWebp512 from '@/assets/loke-clay-512.webp'
import BaseLayout from '@/layouts/BaseLayout.astro'
import PortableText from '@/components/PortableText.astro'
import { getAboutPage } from '@/utils/sanity.queries'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', CACHE_CONTROL.staticPage)

const page = await getAboutPage()
const profileSizes = '256px'
const profileAvifSrcset = `${profileAvif256.src} 256w, ${profileAvif512.src} 512w`
const profileWebpSrcset = `${profileWebp256.src} 256w, ${profileWebp512.src} 512w`

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_DOMAIN },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE_DOMAIN}/about` },
  ],
}
---

<BaseLayout
  title="About"
  description="Learn about my journey as a full-stack web developer, my skills in React, Remix, TypeScript, and modern web technologies, and how I build accessible, performant applications."
  url={`${SITE_DOMAIN}/about`}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="container mx-auto max-w-4xl px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight">{page.title}</h1>
    </header>

    <div class="prose prose-invert max-w-none">
      <div class="flex justify-center mb-6">
        <picture>
          <source type="image/avif" srcset={profileAvifSrcset} sizes={profileSizes} />
          <source type="image/webp" srcset={profileWebpSrcset} sizes={profileSizes} />
          <img
            src={profilePng512.src}
            alt="3D clay avatar"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            width={512}
            height={512}
            class="h-auto w-64 rounded-lg"
          />
        </picture>
      </div>

      <p class="lead text-lg text-muted-foreground">{page.intro}</p>

      {page.sections?.map((section) => (
        <section class="mt-10">
          <h2 class="text-2xl font-bold mb-4">{section.title}</h2>
          <PortableText value={section.content} />
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
