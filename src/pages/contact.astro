---
export const prerender = true

import BaseLayout from '@/layouts/BaseLayout.astro'
import ContactForm from '@/components/ContactForm'
import PageIntro from '@/components/PageIntro.astro'
import { getContactPage } from '@/utils/sanity.queries'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', CACHE_CONTROL.contact)

const page = await getContactPage()
---

<BaseLayout
  title="Contact"
  description={page?.description ?? 'Get in touch with Loke.'}
  url={`${SITE_DOMAIN}/contact`}
  loadTurnstile={true}
>
  <div class="max-w-2xl mx-auto px-4 py-16 md:py-20">
    <PageIntro
      eyebrow="Start a conversation"
      title={page?.title ?? 'Contact'}
      description={page?.description}
      compact
    />

    <div class="mt-10">
      <ContactForm client:load />
    </div>

    {page?.alternativeContactTitle && (
      <div class="mt-12 border-t pt-8">
        <h2 class="text-2xl font-bold mb-4">{page.alternativeContactTitle}</h2>
        {page.alternativeContactDescription && (
          <p class="text-muted-foreground">{page.alternativeContactDescription}</p>
        )}
      </div>
    )}
  </div>
</BaseLayout>
