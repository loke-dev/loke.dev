---
export const prerender = false

import BaseLayout from '@/layouts/BaseLayout.astro'
import BlogPostCard from '@/components/BlogPostCard.astro'
import { getPostsByTopicSlug, getTopicBySlug } from '@/utils/sanity.queries'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', CACHE_CONTROL.blogIndex)
const { slug } = Astro.params
const topicSlug = slug ?? ''
const topic = topicSlug ? await getTopicBySlug(topicSlug) : null
if (!topic) return Astro.redirect('/blog', 302)
const posts = await getPostsByTopicSlug(topicSlug)
const url = `${SITE_DOMAIN}/topics/${topicSlug}`
---

<BaseLayout title={`${topic.title} guides`} description={topic.description} url={url}>
  <section class="mx-auto max-w-6xl px-4 py-16">
    <p class="text-sm font-semibold uppercase tracking-wider text-accent">Topic</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight">{topic.title}</h1>
    <p class="mt-4 max-w-2xl text-lg text-muted-foreground">{topic.description}</p>
    {posts.length ? <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">{posts.map((post) => <BlogPostCard post={post} />)}</div> : <p class="mt-10 text-muted-foreground">Maintained guides for this topic are coming soon.</p>}
  </section>
</BaseLayout>
