---
export const prerender = false

import BaseLayout from '@/layouts/BaseLayout.astro'
import PortableText from '@/components/PortableText.astro'
import PostAdjacentNav from '@/components/PostAdjacentNav.astro'
import PostEvidence from '@/components/PostEvidence.astro'
import RelatedPosts from '@/components/RelatedPosts.astro'
import { getAdjacentPosts, getPostBySlug, getRedirectByFrom, getRelatedPosts } from '@/utils/sanity.queries'
import { formatDate, getSanityImageUrl, getSanityImageSrcSet } from '@/lib/sanity/helpers'
import { getPostUpdatedDisplay } from '@/lib/sanity/post-display'
import { createArticleSchema, createBreadcrumbSchema } from '@/lib/sanity/schema'
import { getDefaultProfileOgUrl } from '@/utils/default-profile-og'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'
import { getRequestSanityClient } from '@/lib/sanity/preview-client'

const { client: contentClient, isPreview } = getRequestSanityClient(Astro.request)
Astro.response.headers.set(
  'Cache-Control',
  isPreview ? 'private, no-store' : CACHE_CONTROL.blogPost
)
const { slug } = Astro.params
if (!slug) return Astro.redirect('/blog', 302)

const post = await getPostBySlug(slug, contentClient)
if (!post) {
  const redirect = await getRedirectByFrom(`/blog/${slug}`)
  if (redirect) return Astro.redirect(redirect.to, redirect.permanent === false ? 302 : 301)
  Astro.response.status = 410
}

const topicIds = post?.topics.map((topic) => topic._id) ?? []
const [relatedPosts, adjacent] = post ? await Promise.all([getRelatedPosts(post._id, topicIds, 3), getAdjacentPosts(post.date)]) : [[], { prev: null, next: null }]
const updatedMeta = post ? getPostUpdatedDisplay(post) : null
const imageUrl = post ? getSanityImageUrl(post.image, 1200, 630) : null
const heroSrcSet = post ? getSanityImageSrcSet(post.image, [640, 768, 1024, 1280, 1600]) : null
const canonicalUrl = `${SITE_DOMAIN}/blog/${slug}`
const defaultImageUrl = getDefaultProfileOgUrl()
const articleSchema = post ? createArticleSchema(post, defaultImageUrl) : null
const breadcrumbSchema = post ? createBreadcrumbSchema([{ name: 'Home', url: SITE_DOMAIN }, { name: 'Blog', url: `${SITE_DOMAIN}/blog` }, { name: post.title, url: canonicalUrl }]) : null
---

{post ? (
  <BaseLayout title={post.title} description={post.description} url={canonicalUrl} image={imageUrl ?? undefined} type="article" publishedTime={post.date} modifiedTime={post.lastModified ?? post._updatedAt ?? post.date} keywords={post.topics.map((topic) => topic.title)}>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <article class="mx-auto max-w-3xl px-4 py-12">
      {imageUrl && <div class="mb-8 -mx-4 sm:-mx-6"><div class="relative aspect-video w-full overflow-hidden rounded-lg bg-muted"><img src={imageUrl} srcset={heroSrcSet ?? undefined} sizes="(min-width: 1280px) 1200px, (min-width: 768px) 768px, 100vw" alt={post.imageAlt ?? `Cover image for ${post.title}`} class="absolute inset-0 h-full w-full object-cover" fetchpriority="high" loading="eager" decoding="async" width={1200} height={675} /></div></div>}
      <header class="mb-8 text-center">
        {post.topics?.length > 0 && <div class="mb-4 flex flex-wrap justify-center gap-2">{post.topics.map((topic) => <a href={`/topics/${topic.slug.current}`} class="rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground hover:underline">{topic.title}</a>)}</div>}
        <h1 class="text-4xl font-bold tracking-tight">{post.title}</h1><p class="mt-4 text-xl text-muted-foreground">{post.description}</p>
        <div class="mt-4 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-sm text-muted-foreground"><span>Published <time datetime={post.date}>{formatDate(post.date)}</time></span>{post.author ? <><span aria-hidden="true">·</span><a class="hover:underline" href={`/authors/${post.author.slug.current}`}>By {post.author.name}</a></> : null}{updatedMeta ? <><span aria-hidden="true">·</span><span>Updated <time datetime={updatedMeta.datetime}>{updatedMeta.label}</time></span></> : null}{post.readingTime ? <><span aria-hidden="true">·</span><span>{post.readingTime} min read</span></> : null}</div>
      </header>
      <PortableText value={post.body} /><PostEvidence sources={post.sources} reproduction={post.reproduction} versionScope={post.versionScope} />
    </article>
    <div class="mx-auto max-w-3xl px-4 pb-16"><PostAdjacentNav prev={adjacent.prev} next={adjacent.next} /><RelatedPosts posts={relatedPosts} /></div>
  </BaseLayout>
) : (
  <BaseLayout title="Article no longer available" description="This article was retired because it no longer met loke.dev's editorial standards." url={canonicalUrl} noindex={true}>
    <section class="mx-auto max-w-2xl px-4 py-24 text-center"><p class="text-sm font-semibold uppercase tracking-wider text-accent">410 · Gone</p><h1 class="mt-3 text-4xl font-bold">This article has been retired.</h1><p class="mt-4 text-lg text-muted-foreground">It no longer met our editorial standards. Browse the current, maintained guides instead.</p><a class="mt-8 inline-flex rounded-md bg-primary px-4 py-2 font-medium text-primary-foreground" href="/blog">Browse the blog</a></section>
  </BaseLayout>
)}
