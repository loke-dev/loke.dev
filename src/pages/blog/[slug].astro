---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PortableText from '@/components/PortableText.astro'
import PostAdjacentNav from '@/components/PostAdjacentNav.astro'
import PostResources from '@/components/PostResources.astro'
import RelatedPosts from '@/components/RelatedPosts.astro'
import {
  getAdjacentPosts,
  getPostBySlug,
  getRelatedPosts,
} from '@/utils/sanity.queries'
import { formatDate, getSanityImageUrl, getSanityImageSrcSet } from '@/lib/sanity/helpers'
import { getPostUpdatedDisplay } from '@/lib/sanity/post-display'
import { createArticleSchema, createBreadcrumbSchema } from '@/lib/sanity/schema'
import { getDefaultProfileOgUrl } from '@/utils/default-profile-og'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', CACHE_CONTROL.blogPost)

const { slug } = Astro.params

if (!slug) {
  return Astro.redirect('/blog', 302)
}

const post = await getPostBySlug(slug)

if (!post) {
  return Astro.redirect('/blog', 302)
}

const tags = post.tags ?? []
const [relatedPosts, adjacent] = await Promise.all([
  getRelatedPosts(post._id, tags, 3),
  getAdjacentPosts(post.date),
])
const updatedMeta = getPostUpdatedDisplay(post)
const imageUrl = getSanityImageUrl(post.image, 1200, 630)
const heroSrcSet = getSanityImageSrcSet(post.image, [640, 768, 1024, 1280, 1600])
const canonicalUrl = `${SITE_DOMAIN}/blog/${slug}`

const defaultImageUrl = await getDefaultProfileOgUrl()

const articleSchema = createArticleSchema(post, defaultImageUrl)
const breadcrumbSchema = createBreadcrumbSchema([
  { name: 'Home', url: SITE_DOMAIN },
  { name: 'Blog', url: `${SITE_DOMAIN}/blog` },
  { name: post.title, url: canonicalUrl },
])
---

<BaseLayout
  title={post.title}
  description={post.description}
  url={canonicalUrl}
  image={imageUrl ?? undefined}
  type="article"
  publishedTime={post.date}
  keywords={tags}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="mx-auto max-w-3xl px-4 py-12">
    {imageUrl && (
      <div class="mb-8 -mx-4 sm:-mx-6">
        <div class="relative aspect-video w-full overflow-hidden rounded-lg bg-muted">
          <img
            src={imageUrl}
            srcset={heroSrcSet ?? undefined}
            sizes="(min-width: 1280px) 1200px, (min-width: 768px) 768px, 100vw"
            alt={post.imageAlt ?? `Cover image for ${post.title}`}
            class="absolute inset-0 h-full w-full object-cover"
            fetchpriority="high"
            loading="eager"
            decoding="async"
            width={1200}
            height={675}
          />
        </div>
      </div>
    )}

    <header class="mb-8 text-center">
      {tags.length > 0 && (
        <div class="mb-4 flex flex-wrap justify-center gap-2">
          {tags.map((tag) => (
            <span class="rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
              {tag}
            </span>
          ))}
        </div>
      )}
      <h1 class="text-4xl font-bold tracking-tight">{post.title}</h1>
      <p class="mt-4 text-xl text-muted-foreground">{post.description}</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-sm text-muted-foreground">
        <span>
          Published{' '}
          <time datetime={post.date}>{formatDate(post.date)}</time>
        </span>
        {updatedMeta && (
          <>
            <span aria-hidden="true">·</span>
            <span>
              Updated{' '}
              <time datetime={updatedMeta.datetime}>{updatedMeta.label}</time>
            </span>
          </>
        )}
        {post.readingTime ? (
          <>
            <span aria-hidden="true">·</span>
            <span>{post.readingTime} min read</span>
          </>
        ) : null}
      </div>
    </header>

    <PortableText value={post.body} />
    {post.resources?.length ? <PostResources resources={post.resources} /> : null}
  </article>

  <div class="mx-auto max-w-3xl px-4 pb-16">
    <PostAdjacentNav prev={adjacent.prev} next={adjacent.next} />
    <RelatedPosts posts={relatedPosts} />
  </div>
</BaseLayout>
