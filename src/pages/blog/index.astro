---
export const prerender = false

import BaseLayout from '@/layouts/BaseLayout.astro'
import BlogListSection from '@/components/BlogListSection.astro'
import { getPaginatedPosts, getBlogPage } from '@/utils/sanity.queries'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', CACHE_CONTROL.blogIndex)

const [paginatedResult, page] = await Promise.all([
  getPaginatedPosts(1),
  getBlogPage(),
])

const { posts, totalPages } = paginatedResult

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_DOMAIN },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_DOMAIN}/blog` },
  ],
}
---

<BaseLayout
  title="Blog"
  description="Maintained, evidence-backed guides for developers solving current problems in JavaScript tooling, CI, and modern web development."
  url={`${SITE_DOMAIN}/blog`}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <BlogListSection
    page={page}
    posts={posts}
    currentPage={1}
    totalPages={totalPages}
  />
</BaseLayout>
