---
import BaseLayout from '@/layouts/BaseLayout.astro'
import BlogPostCard from '@/components/BlogPostCard.astro'
import Pagination from '@/components/Pagination.astro'
import { getPaginatedPosts, getBlogPage, POSTS_PER_PAGE } from '@/utils/sanity.queries'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300')

const pageParam = Astro.url.searchParams.get('page')
const parsed = parseInt(pageParam ?? '1', 10)
const currentPage = Math.max(1, isNaN(parsed) ? 1 : parsed)

const [paginatedResult, page] = await Promise.all([
  getPaginatedPosts(currentPage),
  getBlogPage(),
])

const { posts, totalPages } = paginatedResult

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_DOMAIN },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_DOMAIN}/blog` },
  ],
}
---

<BaseLayout
  title="Blog"
  description="In-depth articles, practical guides, and insights on modern web development. Topics include React, TypeScript, database optimization, AI integration, and building resilient web applications."
  url={`${SITE_DOMAIN}/blog`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="container mx-auto max-w-5xl px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight">{page.title}</h1>
      {page.description && (
        <p class="mt-3 text-lg text-muted-foreground">{page.description}</p>
      )}
    </header>

    {posts.length === 0 ? (
      <div class="rounded-lg border p-8 text-center">
        <h2 class="mb-2 text-xl font-semibold">
          {page.emptyStateTitle ?? 'No posts yet'}
        </h2>
        <p class="text-muted-foreground">
          {page.emptyStateDescription ?? 'Check back soon for new articles!'}
        </p>
      </div>
    ) : (
      <>
        <div class="grid gap-6 sm:grid-cols-2">
          {posts.map((post) => (
            <BlogPostCard post={post} />
          ))}
        </div>

        <Pagination currentPage={currentPage} totalPages={totalPages} />
      </>
    )}
  </div>
</BaseLayout>
