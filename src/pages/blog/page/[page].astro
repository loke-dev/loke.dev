---
export const prerender = false

import BaseLayout from '@/layouts/BaseLayout.astro'
import BlogListSection from '@/components/BlogListSection.astro'
import { getBlogPage, getPaginatedPosts } from '@/utils/sanity.queries'
import { CACHE_CONTROL } from '@/utils/cache-control'
import { SITE_DOMAIN } from '@/utils/meta'

Astro.response.headers.set('Cache-Control', CACHE_CONTROL.blogIndex)

const pageParam = Astro.params.page
const currentPage = Math.max(2, parseInt(pageParam ?? '2', 10))

const [paginatedResult, page] = await Promise.all([
  getPaginatedPosts(currentPage),
  getBlogPage(),
])

const { posts, totalPages } = paginatedResult

if (currentPage > totalPages) {
  return Astro.redirect('/blog', 302)
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_DOMAIN },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_DOMAIN}/blog` },
  ],
}
---

<BaseLayout
  title="Blog"
  description="In-depth articles, practical guides, and insights on modern web development. Topics include React, TypeScript, database optimization, AI integration, and building resilient web applications."
  url={`${SITE_DOMAIN}/blog/page/${currentPage}`}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <BlogListSection
    page={page}
    posts={posts}
    currentPage={currentPage}
    totalPages={totalPages}
  />
</BaseLayout>
