{
  "name": "loke.dev",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 3000",
    "build": "pnpm run content:check && astro build",
    "content:check": "node scripts/check-public-copy.mjs",
    "deploy": "pnpm run build && wrangler deploy",
    "start": "astro preview",
    "cf-typegen": "wrangler types",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "monitoring:status": "node --env-file=.env.monitoring scripts/monitoring-status.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,astro,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,md,json}\"",
    "prepare": "husky",
    "studio": "pnpm --dir studio dev"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/solid-js": "^6.0.1",
    "@portabletext/to-html": "^5.0.2",
    "@sanity/client": "^7.14.0",
    "@sanity/image-url": "^2.0.3",
    "@sanity/webhook": "^4.0.4",
    "@sentry/cloudflare": "^10.65.0",
    "astro": "^6.4.2",
    "clsx": "^2.1.1",
    "resend": "^6.0.2",
    "sharp": "^0.34.5",
    "shiki": "^3.21.0",
    "solid-js": "^1.9.12",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^9.34.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@portabletext/types": "^4.0.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "esbuild": "^0.21",
    "eslint": "^9.34.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.2",
    "vite": "7.3.1",
    "wrangler": "^4.95.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.1"
    },
    "patchedDependencies": {
      "vite@7.3.1": "patches/vite@7.3.1.patch"
    }
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,mdx}": [
      "prettier --write"
    ]
  }
}
